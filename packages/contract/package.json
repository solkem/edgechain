{
  "name": "@edgechain/contract",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "main": "index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "packageManager": "yarn@4.9.2",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    },
    "./dist/managed/edgechain/contract/index.cjs": {
      "default": "./dist/managed/edgechain/contract/index.cjs",
      "require": "./dist/managed/edgechain/contract/index.cjs"
    }
  },
  "scripts": {
    "compact": "yarn compact:edgechain",
    "compact:edgechain": "compact compile src/edgechain.compact ./src/managed/edgechain",
    "compact:sensor-node": "compact compile src/sensor-node.compact ./src/managed/sensor-node",
    "compact:sensor-node-private": "compact compile src/sensor-node-private.compact ./src/managed/sensor-node-private",
    "build": "node ./scripts/build.mjs",
    "build:ts": "tsc --project tsconfig.json",
    "deploy": "npm run build:ts && node dist/deploy-simple.js",
    "deploy:sensor-node": "npm run build:ts && node dist/deploy-device.js",
    "deploy:sensor-node-private": "npm run compact:sensor-node-private && npm run build && node dist/deploy-device.js",
    "view-contract": "npm run build:ts && node dist/view-contract.js",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "yarn build"
  },
  "devDependencies": {
    "eslint": "^9.27.0",
    "jest": "^29.7.0",
    "typescript": "^5.8.2"
  }
}
