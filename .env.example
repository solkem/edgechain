# EdgeChain Environment Configuration

# Midnight Network Configuration
VITE_MIDNIGHT_NETWORK=devnet
VITE_MIDNIGHT_INDEXER_URL=https://indexer.devnet.midnight.network
VITE_MIDNIGHT_INDEXER_WS=wss://indexer.devnet.midnight.network
VITE_MIDNIGHT_PROOF_SERVER=https://proof-server.devnet.midnight.network

# Contract Configuration (set after deployment)
VITE_CONTRACT_ADDRESS=

# Backend API
VITE_API_URL=http://localhost:3001

# Feature Flags
VITE_ENABLE_CONTRACT_INTEGRATION=true
VITE_ENABLE_SMS_BOT=false
VITE_AGENT_ENABLED=false
VITE_VIRTUAL_NDANI_ENABLED=false
VITE_VIRTUAL_NDANI_COORDINATOR_ENABLED=false

# AI Farm Agent pilot foundation
# Backend variables (do not expose these through VITE_ variables)
AGENT_ENABLED=false
VIRTUAL_NDANI_ENABLED=false
VIRTUAL_NDANI_COORDINATOR_ENABLED=false
VIRTUAL_NDANI_SCHEDULING_ENABLED=false
VIRTUAL_NDANI_PHYSICAL_BINDING_ENABLED=false
VIRTUAL_NDANI_PHYSICAL_INGESTION_ENABLED=false
VIRTUAL_NDANI_PIPELINE_DEMO_ENABLED=false
PILOT_ADMIN_ENROLLMENT_KEY=
FARMER_SESSION_SECONDS=43200
# Gemini is server-side only. Keep disabled until GEMINI_API_KEY is configured.
AGENT_LLM_EXTRACTION_ENABLED=false
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_MS=12000
# Cost estimates used for pilot telemetry; update when provider pricing changes.
GEMINI_INPUT_USD_PER_MILLION=0.10
GEMINI_OUTPUT_USD_PER_MILLION=0.40
# Comma-separated exact frontend origins. Required for production pilot cookies.
CORS_ORIGINS=http://localhost:8080
