{
  "name": "edgechain-midnight-hackathon",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "turbo run dev",
    "dev:stack:check": "bash scripts/dev-stack-check.sh",
    "dev:stack:check:full": "bash scripts/dev-stack-check.sh --with-ipfs",
    "dev:stack": "bash scripts/dev-stack.sh",
    "dev:stack:full": "bash scripts/dev-stack.sh --with-ipfs",
    "dev:server": "npm --prefix server run dev",
    "dev:proof-server": "npm --prefix proof-server run dev",
    "dev:ui": "yarn workspace edgechain-ui dev",
    "dev:ipfs": "npm --prefix ipfs-service run dev",
    "dev:health": "curl -fsS http://localhost:3001/health && curl -fsS http://localhost:3002/health && curl -fsS http://localhost:3003/health",
    "predev": "node scripts/check-toolchain.mjs",
    "build": "turbo run build",
    "prebuild": "node scripts/check-toolchain.mjs",
    "build:all": "cd packages/contract && npx turbo run build && cd ../api && npx turbo run build && cd ../cli && npx turbo run build && cd ../ui && npx turbo run build",
    "prebuild:all": "node scripts/check-toolchain.mjs",
    "clean": "turbo run clean",
    "test": "turbo run test",
    "pretest": "node scripts/check-toolchain.mjs",
    "clean:cache": "rm -rf .turbo && rm -rf node_modules/.cache",
    "check:toolchain": "node scripts/check-toolchain.mjs"
  },
  "private": true,
  "resolutions": {
    "@midnight-ntwrk/compact-runtime/@midnight-ntwrk/onchain-runtime": "^0.3.0",
    "@midnight-ntwrk/zswap": "4.0.0"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-js": "2.4.0",
    "@midnight-ntwrk/compact-runtime": "^0.14.0",
    "@midnight-ntwrk/dapp-connector-api": "^4.0.0",
    "@midnight-ntwrk/ledger": "^4.0.0",
    "@midnight-ntwrk/midnight-js-contracts": "^3.0.0",
    "@midnight-ntwrk/midnight-js-fetch-zk-config-provider": "^3.0.0",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "^3.0.0",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "^3.0.0",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "^3.0.0",
    "@midnight-ntwrk/midnight-js-network-id": "^3.0.0",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "^3.0.0",
    "@midnight-ntwrk/midnight-js-types": "^3.0.0",
    "@midnight-ntwrk/midnight-js-utils": "^3.0.0",
    "@midnight-ntwrk/wallet": "5.0.0",
    "@midnight-ntwrk/wallet-api": "^5.0.0",
    "@midnight-ntwrk/wallet-sdk-address-format": "2.0.0",
    "@midnight-ntwrk/wallet-sdk-hd": "2.0.0",
    "@scure/bip39": "^2.0.1",
    "fp-ts": "^2.16.1",
    "io-ts": "^2.2.20",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "rxjs": "^7.8.1",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.6",
    "@types/node": "^22.15.21",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.8.0",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-n": "^16.2.0",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-promise": "^6.1.1",
    "fast-check": "^3.15.0",
    "jest": "^29.7.0",
    "jest-fast-check": "^2.0.0",
    "jest-gh-md-reporter": "^0.0.2",
    "jest-html-reporters": "^3.1.4",
    "jest-junit": "^16.0.0",
    "prettier": "^3.0.3",
    "testcontainers": "^10.27.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "turbo": "2.5.5",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "yarn@4.9.2",
  "workspaces": [
    "compact",
    "packages/ui",
    "packages/api",
    "packages/cli",
    "packages/contract"
  ]
}
